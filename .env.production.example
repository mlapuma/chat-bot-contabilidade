# Copie este arquivo para .env.production na VPS e preencha os valores reais.
# Nunca commite .env.production com token, senha ou dados reais.

POSTGRES_DB=chatbot_contabilidade
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=troque-por-uma-senha-forte

WHATSAPP_CLOUD_ENABLED=true
WHATSAPP_CLOUD_API_VERSION=v23.0
WHATSAPP_CLOUD_PHONE_NUMBER_ID=phone-number-id-do-numero-producao
WHATSAPP_CLOUD_ACCESS_TOKEN=token-permanente-da-meta
WHATSAPP_CLOUD_VERIFY_TOKEN=troque-por-um-token-de-webhook-forte

# Numero inicial combinado para producao: 55 11 97259-2285.
# Observacao: o backend usa WHATSAPP_CLOUD_PHONE_NUMBER_ID, nao o numero digitado.
# Para trocar o numero depois, gere/vincule o novo numero na Meta e troque o PHONE_NUMBER_ID.
